<?xml version="1.0" encoding="utf-8"?>
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Regular (400) -->
    <font
        android:font="@font/syne_regular"
        android:fontStyle="normal"
        android:fontWeight="400"
        app:font="@font/syne_regular"
        app:fontStyle="normal"
        app:fontWeight="400" />

    <!-- SemiBold (600) -->
    <font
        android:font="@font/syne_semibold"
        android:fontStyle="normal"
        android:fontWeight="600"
        app:font="@font/syne_semibold"
        app:fontStyle="normal"
        app:fontWeight="600" />

    <!-- Bold (700) — primary weight for titles -->
    <font
        android:font="@font/syne_bold"
        android:fontStyle="normal"
        android:fontWeight="700"
        app:font="@font/syne_bold"
        app:fontStyle="normal"
        app:fontWeight="700" />

    <!-- ExtraBold (800) — hero headings -->
    <font
        android:font="@font/syne_extrabold"
        android:fontStyle="normal"
        android:fontWeight="800"
        app:font="@font/syne_extrabold"
        app:fontStyle="normal"
        app:fontWeight="800" />

</font-family>
