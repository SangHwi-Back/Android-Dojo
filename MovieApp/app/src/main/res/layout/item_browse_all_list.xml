<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/movie_image_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:adjustViewBounds="true"
        android:scaleType="centerCrop"
        app:shapeAppearance="@style/ShapeAppearance.CineBook.MediumComponent"
        app:layout_constraintDimensionRatio="1:1.4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/info_layout"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_weight="1"
        tools:src="@tools:sample/avatars" />

    <LinearLayout
        android:id="@+id/info_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toEndOf="@id/movie_image_view"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_weight="2.5">

        <TextView
            android:id="@+id/name_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dm_sans_bold"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_lg"
            tools:text="Dune: Part Three" />

        <TextView
            android:id="@+id/point_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dm_sans_semibold"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/text_secondary"
            android:gravity="center_vertical|start"
            app:drawableStartCompat="@drawable/star_fill_24px"
            tools:text="9.2" />

        <TextView
            android:id="@+id/play_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dm_sans_semibold"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/text_secondary"
            android:gravity="center_vertical|start"
            app:drawableStartCompat="@drawable/schedule_outlined_24px"
            tools:text="2h 45m" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
