<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- 포스터 이미지 -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/movie_image_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="H,1:0.5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearance="@style/ShapeAppearance.CineBook.BottomSheet"
        tools:src="@tools:sample/avatars" />

    <!-- 중앙 재생 버튼 -->
    <ImageButton
        android:id="@+id/play_button"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/rounded_icon_background"
        android:backgroundTint="@color/green_primary"
        android:contentDescription="@string/content_desc_close_button"
        android:scaleType="centerCrop"
        android:src="@drawable/play_arrow_24px"
        android:tint="@color/background_primary"
        app:layout_constraintBottom_toBottomOf="@id/movie_image_view"
        app:layout_constraintEnd_toEndOf="@id/movie_image_view"
        app:layout_constraintStart_toStartOf="@id/movie_image_view"
        app:layout_constraintTop_toTopOf="@id/movie_image_view" />

    <!-- 우상단 닫기 버튼 (시트 상단 위로 12dp 돌출) -->
    <ImageButton
        android:id="@+id/close_button"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_date_chip_unselected"
        android:contentDescription="@string/content_desc_close_button"
        android:scaleType="center"
        android:src="@drawable/close_24px"
        android:tint="@color/text_primary"
        android:translationY="-12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 이미지 아래 콘텐츠 영역 -->
    <LinearLayout
        android:id="@+id/contents_linear_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/movie_image_view">

        <!-- 제목 -->
        <TextView
            android:id="@+id/name_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/dm_sans_bold"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xl"
            tools:text="Dune: Part Three" />

        <!-- 평점 · 시간 · 날짜 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/star_fill_24px"
                android:layout_marginEnd="4dp"
                app:tint="@color/icon_green" />

            <TextView
                android:id="@+id/rating_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/dm_sans_bold"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_sm"
                tools:text="9.2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:fontFamily="@font/dm_sans_semibold"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_xs"
                android:text=" /10" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/schedule_outlined_24px"
                android:layout_marginEnd="4dp"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/duration_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:fontFamily="@font/dm_sans_semibold"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm"
                tools:text="2h 45m" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/calendar_today_outlined_24px"
                android:layout_marginEnd="4dp"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/release_date_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/dm_sans_semibold"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm"
                tools:text="2026-03-15" />
        </LinearLayout>

        <!-- 장르 칩 RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/category_chip_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:nestedScrollingEnabled="false"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- 설명 -->
        <TextView
            android:id="@+id/description_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/dm_sans_regular"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm"
            android:lineSpacingMultiplier="1.4"
            tools:text="The epic conclusion to the Dune saga follows Paul Atreides as he unites with the Fremen people of the desert planet Arrakis." />

        <!-- 하단 버튼 두 개 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/book_now_button"
                android:layout_width="0dp"
                android:layout_weight="1.2"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/dm_sans_semibold"
                android:text="@string/action_book_now"
                android:textColor="@color/badge_text"
                app:backgroundTint="@color/green_accent"
                app:cornerRadius="24dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_to_list_button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:fontFamily="@font/dm_sans_semibold"
                android:text="@string/action_add_to_list"
                android:textColor="@color/text_primary"
                app:backgroundTint="@color/background_tertiary"
                app:cornerRadius="24dp"
                app:strokeWidth="0dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
