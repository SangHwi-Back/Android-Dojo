<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".book.BookTheaterFragment">

    <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/movie_view_pager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/movie_view_pager"/>

    <TextView
            android:id="@+id/select_theater_title_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="8dp"
            android:fontFamily="@font/dm_sans_bold"
            android:gravity="center_vertical"
            android:text="@string/label_select_theater"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_lg"
            app:drawableStartCompat="@drawable/play_arrow_24px"
            app:drawableTint="@color/green_accent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/movie_view_pager"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/scroll_view"/>

    <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_view"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/movie_view_pager"
            app:layout_constraintBottom_toTopOf="@id/next_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/theater_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
            android:id="@+id/next_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:enabled="false"
            android:fontFamily="@font/dm_sans_semibold"
            android:text="@string/action_next"
            android:textColor="@color/badge_text"
            app:backgroundTint="@color/green_accent"
            app:cornerRadius="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeWidth="0dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
